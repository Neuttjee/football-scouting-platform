generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerType {
  INTERNAL
  EXTERNAL
}

enum ClubStatus {
  ACTIEF
  INACTIEF
  PROEFPERIODE
  GESCHORST
}

enum BillingStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  PAUSED
  CANCELED
}

model Club {
  id             String          @id @default(uuid())
  name           String
  shortName      String?
  logo           String?
  primaryColor   String?
  secondaryColor String?
  agingThreshold Int             @default(30)
  status         ClubStatus      @default(ACTIEF)
  trialStartsAt  DateTime?
  trialEndsAt    DateTime?
  billingStatus  BillingStatus   @default(ACTIVE)
  billingProvider String?
  billingCustomerId String?
  billingSubscriptionId String?

  contactName    String?
  contactEmail   String?
  contactPhone   String?

  settings       ClubSettings?
  features       ClubFeature[]
  subscription   ClubSubscription?
  internalNote   ClubInternalNote?

  users          User[]
  teams          Team[]
  players        Player[]
  contacts       ContactMoment[]
  tasks          Task[]
  squadPlans     SquadPlan[]

  auditLogs      AuditLog[]      @relation("ClubAuditLogs")
  tablePreferences UserTablePreference[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ClubSettings {
  id          String   @id @default(uuid())
  clubId      String   @unique
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  maxUsers    Int      @default(999)
  settingsJson Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClubFeature {
  id        String   @id @default(uuid())
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  key       String
  enabled   Boolean  @default(false)
  configJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, key])
  @@index([clubId])
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PREMIUM
  CUSTOM
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PAID
  OPEN
  PAST_DUE
}

enum PaymentMethod {
  MANUAL
  INVOICE
  DIRECT_DEBIT
}

model ClubSubscription {
  id                     String             @id @default(uuid())
  clubId                 String             @unique
  club                   Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)

  plan                   SubscriptionPlan
  status                 SubscriptionStatus
  billingCycle           BillingCycle

  priceMinor             Int?
  currency               String             @default("EUR")

  startsAt               DateTime?
  renewsAt               DateTime?
  endsAt                 DateTime?

  paymentStatus          PaymentStatus
  paymentMethod          PaymentMethod

  invoiceReference       String?
  customerNumber         String?

  notes                  String?

  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?

  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
}

model ClubInternalNote {
  id        String   @id @default(uuid())
  clubId    String   @unique
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String?
  name                 String
  role                 String    // "SUPERADMIN", "ADMIN", "TC_LID", "SCOUT", "LEZER"
  isActive             Boolean   @default(true)

  inviteToken          String?   @unique
  inviteTokenExpires   DateTime?

  clubId               String
  club                 Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  // 2FA Fields (Post-MVP)
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String?
  twoFactorVerifiedAt  DateTime?
  twoFactorResetAt     DateTime?

  // Audit Relations
  playersCreated       Player[]        @relation("PlayerCreatedBy")
  contactsCreated      ContactMoment[] @relation("ContactCreatedBy")
  tasksCreated         Task[]          @relation("TaskCreatedBy")
  tasksAssigned        Task[]          @relation("TaskAssignedTo")
  squadPlans           SquadPlan[]
  auditLogs            AuditLog[]      @relation("UserAuditLogs")
  tablePreferences     UserTablePreference[]

  loginCount           Int       @default(0)
  lastLoginAt          DateTime?

  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Player {
  id                    String   @id @default(uuid())
  name                  String
  type                  PlayerType @default(EXTERNAL)
  position              String?
  secondaryPosition     String?
  favoritePosition      String?
  preferredFoot         String?
  team                  String?
  teamId                String?
  teamRef               Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  dateOfBirth           DateTime?
  age                   Int?
  joinedAt              DateTime?
  contractEndDate       DateTime?
  optionYear            Boolean  @default(false)
  isTopTalent           Boolean  @default(false)
  distanceFromClubKm    Int?

  // New fields
  currentClub           String?
  advies                String?
  niveau                String?
  contactPerson         String?
  notes                 String?

  // Target status logic
  step                  String?
  status                String?
  statusManuallyChanged Boolean  @default(false)

  clubId                String
  club                  Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdById           String?
  createdBy             User?    @relation("PlayerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  contacts              ContactMoment[]
  tasks                 Task[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Team {
  id           String   @id @default(uuid())
  clubId       String
  club         Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name         String
  code         String?
  niveau       String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  players      Player[]
  squadPlans   SquadPlan[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clubId, isActive, displayOrder])
}

model ContactMoment {
  id          String   @id @default(uuid())
  type        String
  channel     String
  outcome     String?
  reason      String?
  notes       String?

  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  clubId      String
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?    @relation("ContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id                     String   @id @default(uuid())
  title                  String
  description            String?
  isCompleted            Boolean  @default(false)
  dueDate                DateTime?
  assignedToExternalName String?

  clubId                 String
  club                   Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  assignedToId           String?
  assignedTo             User?    @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById            String?
  createdBy              User?    @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  playerId               String?
  player                 Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model SquadPlan {
  id             String   @id @default(uuid())

  clubId         String
  club           Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  teamId         String
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  seasonYear     Int
  formation      String
  assignmentsJson Json
  isClubDefault  Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clubId, teamId, seasonYear, userId, isClubDefault])
}

model UserTablePreference {
  id              String   @id @default(uuid())

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  clubId          String
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  /// Logical key identifying the table, e.g. "players" or "internalPlayers".
  tableKey        String

  /// Column visibility per column id.
  columnVisibility Json

  /// Sorting state as TanStack SortingState.
  sorting         Json

  /// Optional column order for future drag & drop reordering.
  columnOrder     Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, clubId, tableKey])
  @@index([userId, clubId])
}

model AuditLog {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())

  actorId    String?
  actor      User?    @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)

  clubId     String?
  club       Club?    @relation("ClubAuditLogs", fields: [clubId], references: [id], onDelete: SetNull)

  actorRole  String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?

  ipAddress  String?
  userAgent  String?

  @@index([clubId, createdAt])
  @@index([action, createdAt])
}
